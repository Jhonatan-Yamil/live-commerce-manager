# Public domain that points to your EC2 public IP
DOMAIN_NAME=app.tudominio.com

# Database
POSTGRES_DB=livesale
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# Backend auth
SECRET_KEY=CHANGE_ME_SUPER_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Telegram
TELEGRAM_BOT_TOKEN=CHANGE_ME_BOT_TOKEN
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET
TELEGRAM_WEBHOOK_AUTO_SETUP=true
TELEGRAM_PUBLIC_BASE_URL=https://app.tudominio.com
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=false

# Intake
INTAKE_ASYNC_ENABLED=true
INTAKE_QUEUE_BACKEND=memory
INTAKE_QUEUE_KEY=live-sale:intake-queue
INTAKE_WORKER_EMBEDDED=true
INTAKE_MAX_FILE_SIZE_MB=10
INTAKE_HASH_DEDUP_WINDOW_HOURS=24

# CORS: use your real public origin
CORS_ORIGINS=https://app.tudominio.com
