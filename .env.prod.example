# ============= PRODUCTION CONFIGURATION FOR LIVE COMMERCE MANAGER =============
# This file should be used as a template for setting GitHub secrets
# Store actual values in GitHub Settings > Secrets and variables > Actions > PROD_ENV_FILE

# ============= DOMAIN & DNS =============
# For livecommerce.duckdns.org - already pointing to Elastic IP
DOMAIN_NAME=livecommerce.duckdns.org

# ============= DATABASE =============
POSTGRES_DB=livesale
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD_MIN_12_CHARS

# ============= AUTHENTICATION & TOKENS =============
SECRET_KEY=CHANGE_ME_TO_SECURE_SECRET_KEY_MIN_32_CHARS_RANDOM
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============= TELEGRAM BOT INTEGRATION =============
# Get these from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_TO_RANDOM_SECRET_STRING_MIN_20_CHARS
TELEGRAM_WEBHOOK_AUTO_SETUP=true
TELEGRAM_PUBLIC_BASE_URL=https://livecommerce.duckdns.org
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=false

# ============= ASYNC INTAKE QUEUE =============
INTAKE_ASYNC_ENABLED=true
INTAKE_QUEUE_BACKEND=memory
INTAKE_QUEUE_KEY=live-sale:intake-queue
INTAKE_WORKER_EMBEDDED=true
INTAKE_MAX_FILE_SIZE_MB=10
INTAKE_HASH_DEDUP_WINDOW_HOURS=24

# ============= REDIS (Cache & Queue Backend) =============
REDIS_URL=redis://redis:6379/0

# ============= CORS & ORIGINS =============
CORS_ORIGINS=https://livecommerce.duckdns.org

# ============= FILE STORAGE =============
UPLOADS_DIR=uploads

# ============= FRONTEND API =============
# Relative path for production behind reverse proxy
REACT_APP_API_URL=/api
