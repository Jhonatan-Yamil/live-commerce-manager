# ============= DATABASE =============
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/livesale

# ============= AUTHENTICATION & TOKENS =============
SECRET_KEY=changeme-super-secret-key-livesale-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============= TELEGRAM BOT INTEGRATION =============
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-here
TELEGRAM_WEBHOOK_AUTO_SETUP=true
TELEGRAM_PUBLIC_BASE_URL=
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=false
NGROK_API_URL=http://127.0.0.1:4040
NGROK_AUTHTOKEN=

# ============= ASYNC INTAKE QUEUE =============
INTAKE_ASYNC_ENABLED=true
INTAKE_QUEUE_BACKEND=memory
INTAKE_QUEUE_KEY=live-sale:intake-queue
INTAKE_WORKER_EMBEDDED=true
INTAKE_MAX_FILE_SIZE_MB=10
INTAKE_HASH_DEDUP_WINDOW_HOURS=24

# ============= REDIS (Cache & Queue Backend) =============
REDIS_URL=redis://localhost:6379/0

# ============= CORS & ORIGINS =============
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============= FILE STORAGE =============
UPLOADS_DIR=uploads

# ============= FRONTEND API =============
REACT_APP_API_URL=http://localhost:8000/api

# ============= DATABASE (Docker Compose) =============
# Only needed if using Docker Compose (overrides defaults)
# POSTGRES_DB=livesale
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# ============= PRODUCTION (Compose + Caddy) =============
# DOMAIN_NAME is required to enable automatic HTTPS with Caddy.
# DOMAIN_NAME=app.tudominio.com

# ============= TERRAFORM (AWS) =============
# Optional: Terraform reads TF_VAR_* automatically.
# TF_VAR_aws_region=us-east-1
# TF_VAR_project_name=live-commerce-manager
# TF_VAR_instance_type=t3a.small
# TF_VAR_ssh_cidr=0.0.0.0/0
# TF_VAR_key_pair_name=my-existing-keypair
